#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
use Kytarna\Command\AdminCreateCommand;
use Kytarna\Command\MigrationGenerateCommand;
use Kytarna\Command\MigrationRunCommand;

$application = new Application();

$application->addCommand(new AdminCreateCommand());
$application->addCommand(new MigrationGenerateCommand());
$application->addCommand(new MigrationRunCommand());

$application->run();
