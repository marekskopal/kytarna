#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
use Kytario\Command\AdminCreateCommand;
use Kytario\Command\MigrationGenerateCommand;
use Kytario\Command\MigrationRunCommand;
use Kytario\Command\NotificationDueTickCommand;

$application = new Application();

$application->addCommand(new AdminCreateCommand());
$application->addCommand(new MigrationGenerateCommand());
$application->addCommand(new MigrationRunCommand());
$application->addCommand(new NotificationDueTickCommand());

$application->run();
