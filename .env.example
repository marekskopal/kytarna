# =============================================================================
# Kytario environment configuration
#
# Copy to `.env` and adjust. The values below are the local-dev defaults — the
# stack boots out of the box with them. Before deploying, work through every
# var tagged below.
#
# Legend:
#   [prod-required]  Backend refuses to boot without it (any APP_ENV).
#   [MUST CHANGE]    Secret-bearing. Replace the dev default before prod;
#                    with APP_ENV=production the backend rejects the default
#                    or any value shorter than 16 chars.
#   [prod]           Must be set/tightened specifically when APP_ENV=production.
#   [optional]       Safe to leave as-is or empty.
#
# Generate strong secrets with:  openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# Application & proxy
# -----------------------------------------------------------------------------
# `development` (default) or `production`. When set to `production` the backend
# refuses to boot with default/short MYSQL/S3 secrets or a wildcard CORS origin
# (see the tagged vars below).
APP_ENV=development
# Host the proxy serves on.
# Prod example: PROXY_HOST=app.example.com
PROXY_HOST=localhost
PROXY_PORT=4300
# Optional HTTPS. Activate with `docker compose -f docker-compose.yml -f docker-compose.ssl.yml`.
# [optional] Leave blank for plain HTTP (dev) or when terminating TLS upstream.
PROXY_PORT_SSL=7281
PROXY_SSL_CERT=
PROXY_SSL_KEY=
BACKEND_FRANKENPHP_WORKERS=4
# `production` (errors+warnings) or `debug` (verbose). Keep `production` in prod.
BACKEND_LOG_LEVEL=production

# -----------------------------------------------------------------------------
# Database (MariaDB)
# -----------------------------------------------------------------------------
MYSQL_HOST=db                  # [prod-required]
MYSQL_DATABASE=kytario          # [prod-required]
MYSQL_USER=kytario              # [prod-required]
MYSQL_PASSWORD=kytario          # [prod-required] [MUST CHANGE]
MYSQL_ROOT_PASSWORD=kytario     # [MUST CHANGE]

# -----------------------------------------------------------------------------
# Auth & security
# -----------------------------------------------------------------------------
# [prod-required] [MUST CHANGE] App-wide JWT signing key, min 32 chars.
# The placeholder below is rejected on boot — generate with `openssl rand -hex 32`.
AUTHORIZATION_TOKEN_KEY=replace-with-32-char-random-hex-key-here
# [optional] Google OAuth web client ID. Leave empty to hide the
# "Sign in with Google" button. Obtain one at:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# [prod] Allowed Origin(s) for cross-origin browser calls to /api/*.
# `*` is fine for local dev. With APP_ENV=production the backend
# refuses to boot on `*` — set an explicit space- or comma-separated list.
# Prod example: BACKEND_CORS_ALLOWED_ORIGIN=https://app.example.com https://staging.example.com
BACKEND_CORS_ALLOWED_ORIGIN=*
# Failed-login backoff: after N consecutive failures on the same account, the
# account is temporarily locked. Backoff doubles with each subsequent failure
# (60s, 120s, 300s, 900s, 1800s) and tops out at RATE_LIMIT_LOGIN_BACKOFF_CAP_SECONDS.
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_BACKOFF_CAP_SECONDS=3600
# Max invitations a single workspace can create in a rolling 1-hour window.
RATE_LIMIT_INVITATIONS_PER_HOUR=50
# Max password-reset emails a single account can trigger in a rolling 1-hour window.
# Silently capped server-side (the response is always generic to avoid user enumeration).
RATE_LIMIT_PASSWORD_RESETS_PER_HOUR=5

# -----------------------------------------------------------------------------
# Mailer (SMTP) — invitations, notifications
# -----------------------------------------------------------------------------
# Dev defaults point at the bundled `mailpit` capture container. In prod point
# these at a real SMTP relay.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=                     # [optional] set if your relay requires auth
SMTP_PASSWORD=                 # [optional] [MUST CHANGE] set if your relay requires auth
# From address on outgoing mail. Prod example: EMAIL_FROM=no-reply@example.com
EMAIL_FROM=no-reply@kytario.local

# -----------------------------------------------------------------------------
# Object storage (S3 / MinIO) — lecture file attachments
# -----------------------------------------------------------------------------
# Dev defaults target the bundled `minio` container. In prod point these at your
# S3-compatible endpoint.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=kytario-files         # [prod-required]
S3_ACCESS_KEY=minioadmin       # [prod-required] [MUST CHANGE]
S3_SECRET_KEY=minioadmin       # [prod-required] [MUST CHANGE]
# `true` for MinIO / path-style endpoints; `false` for virtual-hosted AWS S3.
S3_USE_PATH_STYLE=true
LECTURE_FILE_MAX_SIZE_MB=25

# -----------------------------------------------------------------------------
# Cache & queue
# -----------------------------------------------------------------------------
REDIS_HOST=redis               # [prod-required]
REDIS_PORT=6379                # [prod-required]
REDIS_PASSWORD=kytario          # [prod-required] [MUST CHANGE]
MEMCACHED_HOST=memcached       # [prod-required]
MEMCACHED_PORT=11211           # [prod-required]
# RabbitMQ — drives async email delivery via the supervisor-managed amqp-consumer
# inside the backend container.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=kytario
RABBITMQ_PASSWORD=kytario       # [MUST CHANGE]
# Per-queue prefetch (basic_qos) for the consumer — caps in-flight unacked messages per channel.
BACKEND_AMQP_CONSUMER_PREFETCH=10

# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------
# OAuth/MCP session lifetime in seconds (default 24h).
MCP_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# Tab service (Node + alphaTab) — validates alphaTex and converts Guitar Pro files
# -----------------------------------------------------------------------------
# URL the backend uses to reach the tab-service over the internal network.
TAB_SERVICE_URL=http://tab-service:8080
TAB_SERVICE_PORT=8080
# Max request body the tab-service accepts (bytes); guards .gp uploads. Default 10 MiB.
TAB_SERVICE_MAX_BODY_BYTES=10485760

# -----------------------------------------------------------------------------
# Adminer (dev-only DB UI, `--profile dev`)
# -----------------------------------------------------------------------------
ADMINER_USER=                  # [optional] dev only
ADMINER_PASSWORD=              # [optional] dev only
